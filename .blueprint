updated:
    - routes/web.php
models:
    Sucursal: { nombre: string, direccion: string, ciudad: string, telefono: 'nullable string', email: 'nullable string unique', activa: 'boolean default:true', softdeletes: softDeletes, relationships: { hasMany: 'Habitacion, User' } }
    User: { sucursal_id: 'nullable id:sucursal', is_super_admin: 'boolean default:false', activo: 'boolean default:true', relationships: { belongsTo: Sucursal } }
    Habitacion: { sucursal_id: 'id:sucursal', numero: string, tipo: 'enum:individual,doble,suite', piso: unsignedInteger, capacidad: 'unsignedInteger default:1', estado: 'enum:disponible,ocupada,sucia,en_limpieza,limpia,inspeccionada,fuera_de_servicio default:disponible', nfc_tag_uid: 'nullable string unique', notas: 'nullable text', softdeletes: softDeletes, relationships: { belongsTo: Sucursal, hasMany: 'Estancia, TareaLimpieza, ReporteMantenimiento, VisitaHabitacion' } }
    Residente: { nombre: string, apellidos: string, fecha_nacimiento: date, curp: 'nullable string unique', diagnostico: 'nullable text', alergias: 'nullable text', contacto_emergencia: string, telefono_emergencia: string, foto_path: 'nullable string', softdeletes: softDeletes, relationships: { hasMany: 'Estancia, VisitaHabitacion' } }
    Estancia: { residente_id: 'id:residente', habitacion_id: 'id:habitacion', fecha_ingreso: date, fecha_egreso: 'nullable date', estado: 'enum:activa,alta,traslado,fallecimiento default:activa', notas_medicas: 'nullable text', relationships: { belongsTo: 'Residente, Habitacion' } }
    RondaEnfermeria: { enfermera_id: 'id:user', turno: 'enum:matutino,vespertino,nocturno', fecha: date, hora_inicio_programada: time, hora_fin_programada: time, hora_inicio_real: 'nullable time', hora_fin_real: 'nullable time', estado: 'enum:pendiente,en_curso,completada,incompleta default:pendiente', notas: 'nullable text', relationships: { belongsTo: User, hasMany: 'VisitaHabitacion, AlertaRonda', hasOne: ReporteEnfermeria } }
    VisitaHabitacion: { ronda_enfermeria_id: 'id:ronda_enfermeria', habitacion_id: 'id:habitacion', residente_id: 'id:residente', hora_programada: time, nfc_verificado: 'boolean default:false', nfc_escaneado_at: 'nullable datetime', estado: 'enum:pendiente,en_progreso,completada,omitida default:pendiente', notas: 'nullable text', relationships: { belongsTo: 'RondaEnfermeria, Habitacion, Residente', hasMany: ChecklistEnfermeriaItem } }
    ChecklistEnfermeriaItem: { visita_habitacion_id: 'id:visita_habitacion', descripcion: string, completado: 'boolean default:false', valor: 'nullable string', orden: 'unsignedInteger default:0', relationships: { belongsTo: VisitaHabitacion } }
    ReporteEnfermeria: { ronda_enfermeria_id: 'id:ronda_enfermeria', enfermera_id: 'id:user', incidencias: 'nullable text', observaciones: 'nullable text', firmado_at: 'nullable datetime', estado: 'enum:borrador,firmado default:borrador', relationships: { belongsTo: RondaEnfermeria } }
    AlertaRonda: { ronda_enfermeria_id: 'id:ronda_enfermeria', visita_habitacion_id: 'nullable id:visita_habitacion', tipo: 'enum:visita_tardia,visita_omitida,turno_incompleto', atendido: 'boolean default:false', atendido_por_id: 'nullable id:user', relationships: { belongsTo: RondaEnfermeria } }
    TareaLimpieza: { habitacion_id: 'id:habitacion', camarera_id: 'nullable id:user', supervisora_id: 'nullable id:user', tipo: 'enum:salida,estancia,profunda,llegada', prioridad: 'enum:baja,normal,alta,urgente default:normal', estado: 'enum:pendiente,en_progreso,completada,inspeccionada,rechazada default:pendiente', fecha_programada: date, hora_inicio: 'nullable time', hora_fin: 'nullable time', notas: 'nullable text', relationships: { belongsTo: Habitacion, hasMany: 'ChecklistItem, Inspeccion' } }
    ChecklistItem: { tarea_limpieza_id: 'id:tarea_limpieza', descripcion: string, completado: 'boolean default:false', orden: 'unsignedInteger default:0', relationships: { belongsTo: TareaLimpieza } }
    Inspeccion: { tarea_limpieza_id: 'id:tarea_limpieza', supervisora_id: 'id:user', resultado: 'enum:aprobada,rechazada', puntaje: 'nullable unsignedInteger', notas: 'nullable text', relationships: { belongsTo: TareaLimpieza } }
    ReporteMantenimiento: { habitacion_id: 'id:habitacion', reportado_por_id: 'id:user', descripcion: text, prioridad: 'enum:baja,normal,alta,urgente default:normal', estado: 'enum:pendiente,en_proceso,resuelto default:pendiente', foto_path: 'nullable string', notas_resolucion: 'nullable text', relationships: { belongsTo: Habitacion } }
